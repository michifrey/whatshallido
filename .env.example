# Admin-Token für den /admin-Bereich (in Produktion unbedingt ändern!)
ADMIN_TOKEN=change-me

# Optionaler Unsplash Access Key für die Bildersuche im Admin
# Kostenlos erhältlich unter https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# Port des Servers (Standard 3000)
PORT=3000

# Pfad zur SQLite-Datenbank
DATABASE_PATH=./data/berufe.db
