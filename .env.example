# Admin-Token für den /admin-Bereich (in Produktion unbedingt ändern!)
ADMIN_TOKEN=change-me

# Optionaler Unsplash Access Key für die Bildersuche im Admin
# Kostenlos erhältlich unter https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# Optionaler Anthropic API Key für «mit KI verbessern» im Bewerbungs-Helfer
# Schlüssel von https://console.anthropic.com
ANTHROPIC_API_KEY=
# Optional: KI-Modell überschreiben (Standard: claude-opus-4-8)
ANTHROPIC_MODEL=

# Port des Servers (Standard 3001)
PORT=3001

# Pfad zur SQLite-Datenbank
DATABASE_PATH=./data/berufe.db
